{
  "name": "senado-br-mcp",
  "version": "3.3.1",
  "description": "MCP server for Brazilian Senate open data — runs hosted on Cloudflare Workers or locally via npx (stdio)",
  "license": "MIT",
  "type": "module",
  "mcpName": "io.github.SidneyBissoli/senado-br-mcp-cloudflare",
  "bin": {
    "senado-br-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:ecidadania": "tsx scripts/ingest-ecidadania/index.ts",
    "ingest:ecidadania:eventos": "tsx scripts/ingest-ecidadania/index-eventos.ts",
    "ingest:ecidadania:ideias": "tsx scripts/ingest-ecidadania/index-ideias.ts",
    "ingest:ecidadania:consultas-votos": "tsx scripts/ingest-ecidadania/index-consultas-votos.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@types/node": "^25.9.3",
    "agents": "^0.5.0",
    "exceljs": "^4.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "fast-uri": "^4.0.0",
    "hono": "^4.12.27",
    "@hono/node-server": "^1.19.13",
    "express-rate-limit": "^8.5.2",
    "ip-address": "^10.2.0",
    "qs": "^6.15.3",
    "path-to-regexp": "^8.4.2",
    "lodash": "^4.18.1",
    "js-yaml": "^4.2.0",
    "undici": "^7.28.0",
    "ws": "^8.21.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  }
}
