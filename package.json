{
  "name": "senado-br-mcp-cloudflare",
  "version": "3.1.0",
  "description": "MCP server for Brazilian Senate open data, running on Cloudflare Workers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:ecidadania": "tsx scripts/ingest-ecidadania/index.ts",
    "ingest:ecidadania:eventos": "tsx scripts/ingest-ecidadania/index-eventos.ts",
    "ingest:ecidadania:ideias": "tsx scripts/ingest-ecidadania/index-ideias.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "agents": "^0.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0"
  }
}
