{
  "name": "senado-br-mcp",
  "version": "3.2.0",
  "description": "MCP server for Brazilian Senate open data — runs hosted on Cloudflare Workers or locally via npx (stdio)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "senado-br-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:ecidadania": "tsx scripts/ingest-ecidadania/index.ts",
    "ingest:ecidadania:eventos": "tsx scripts/ingest-ecidadania/index-eventos.ts",
    "ingest:ecidadania:ideias": "tsx scripts/ingest-ecidadania/index-ideias.ts",
    "ingest:ecidadania:consultas-votos": "tsx scripts/ingest-ecidadania/index-consultas-votos.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "agents": "^0.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0"
  }
}
